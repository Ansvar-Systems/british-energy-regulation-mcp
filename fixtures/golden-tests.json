{
  "version": "1.0",
  "mcp_name": "British Energy Regulation MCP",
  "tests": [
    {
      "id": "gb-energy-001",
      "category": "search",
      "description": "Search regulations for 'electricity'",
      "tool": "gb_energy_search_regulations",
      "input": { "query": "electricity" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "gb-energy-002",
      "category": "data_retrieval",
      "description": "Get regulation by reference (Electricity Act 1989)",
      "tool": "gb_energy_get_regulation",
      "input": { "reference": "Electricity Act 1989 c.29" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "gb-energy-003",
      "category": "search",
      "description": "Search grid codes for 'balancing'",
      "tool": "gb_energy_search_grid_codes",
      "input": { "query": "balancing" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "gb-energy-004",
      "category": "data_retrieval",
      "description": "Get grid code by document ID",
      "tool": "gb_energy_get_grid_code",
      "input": { "document_id": 2 },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "gb-energy-005",
      "category": "search",
      "description": "Search decisions for 'price control'",
      "tool": "gb_energy_search_decisions",
      "input": { "query": "price control" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "gb-energy-006",
      "category": "meta_tool",
      "description": "About tool returns server metadata",
      "tool": "gb_energy_about",
      "input": {},
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "gb-energy-007",
      "category": "negative_test",
      "description": "Non-existent regulation reference handles gracefully",
      "tool": "gb_energy_get_regulation",
      "input": { "reference": "NONEXISTENT-REF-999" },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "gb-energy-008",
      "category": "negative_test",
      "description": "Non-existent grid code ID handles gracefully",
      "tool": "gb_energy_get_grid_code",
      "input": { "document_id": 99999 },
      "assertions": { "handles_gracefully": true }
    },
    {
      "id": "gb-energy-009",
      "category": "search",
      "description": "Search regulations with regulator filter",
      "tool": "gb_energy_search_regulations",
      "input": { "query": "safety", "regulator": "hse" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "gb-energy-010",
      "category": "search",
      "description": "Search regulations with type filter",
      "tool": "gb_energy_search_regulations",
      "input": { "query": "energy", "type": "act" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    },
    {
      "id": "gb-energy-011",
      "category": "search",
      "description": "Search grid codes by code_type",
      "tool": "gb_energy_search_grid_codes",
      "input": { "query": "code", "code_type": "industry_code" },
      "assertions": { "result_not_empty": true }
    },
    {
      "id": "gb-energy-012",
      "category": "cross_reference",
      "description": "Search decisions for enforcement actions",
      "tool": "gb_energy_search_decisions",
      "input": { "query": "enforcement", "decision_type": "enforcement" },
      "assertions": { "result_not_empty": true, "min_results": 1 }
    }
  ]
}
